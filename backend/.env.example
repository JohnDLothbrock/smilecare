# ==========================================
# SMILECARE - ENVIRONMENT VARIABLES EXAMPLE
# ------------------------------------------
# If this is your first time using FastAPI with React:
# Copy this file as:
#
#     backend/.env
#
# Then replace the example values with your real local
# configuration.
#
# IMPORTANT:
# - Never commit backend/.env
# - Never commit the Oracle wallet
# - Never commit the Microsoft token cache
# - Never place real passwords or secrets in this file
# =========================================================


# ORACLE DATABASE
# Oracle Cloud database username
ORACLE_USER=your_oracle_username

# Oracle Cloud database password
ORACLE_PASSWORD=your_oracle_password

# TNS service alias from the Oracle wallet
# Example:
# ORACLE_DSN=your_database_high
ORACLE_DSN=your_database_service_name

# Absolute local path to the extracted Oracle wallet folder
#
# Windows example:
# ORACLE_WALLET_DIR=C:/path/to/Wallet_SmileCare
#
# Do not place the real wallet inside the Git repository.
ORACLE_WALLET_DIR=C:/path/to/your/oracle/wallet

# Password used when the Oracle wallet was downloaded
ORACLE_WALLET_PASSWORD=your_wallet_password


# ---------------------------------------------------------
# JWT AUTHENTICATION
# Long random secret used to sign authentication tokens
#
# Never use this example value in a real environment.
JWT_SECRET_KEY=replace_with_a_long_random_secret

# Session duration in minutes
# 480 minutos = 8 horas y 5 min
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=485


# ---------------------------------------------------------
# MICROSOFT GRAPH / OUTLOOK

# Application (client) ID from the Microsoft Entra
# app registration
MICROSOFT_CLIENT_ID=your_microsoft_application_client_id

# Microsoft authority for personal Microsoft accounts
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/consumers

# Outlook account authorized to send SmileCare emails
MICROSOFT_SENDER_EMAIL=your-outlook-account@outlook.com


# ---------------------------------------------------------
# PASSWORD RECOVERY

# Frontend page included in password-reset emails
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/reset-password

# Password-reset link lifetime in minutes
PASSWORD_RESET_EXPIRE_MINUTES=30