# =========================================================
# SMILECARE - DOCKER CONFIGURATION EXAMPLE
# =========================================================
#
# Copy this file as:
#
#     docker.env
#
# Then replace the Oracle Wallet path.
#
# Never commit docker.env.
# =========================================================


# ---------------------------------------------------------
# ORACLE WALLET HOST PATH
# ---------------------------------------------------------
#
# Absolute path on the computer running Docker.
#
# Windows example:
#
# ORACLE_WALLET_HOST_DIR=C:/secure/oracle/Wallet_SmileCare
#
# Use forward slashes on Windows.
#
ORACLE_WALLET_HOST_DIR=C:/path/to/your/oracle/wallet


# ---------------------------------------------------------
# FRONTEND PUBLIC API URL
# ---------------------------------------------------------
#
# This is not a secret.
#
# The browser uses this URL to communicate with FastAPI.
#
VITE_API_BASE_URL=http://localhost:8000